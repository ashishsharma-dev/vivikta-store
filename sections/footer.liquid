{% comment %}theme-check-disable UndefinedObject{% endcomment %}
{{ 'section-footer.css' | asset_url | stylesheet_tag }}
{{ 'component-newsletter.css' | asset_url | stylesheet_tag }}
{{ 'component-list-menu.css' | asset_url | stylesheet_tag }}
{{ 'component-list-payment.css' | asset_url | stylesheet_tag }}
{{ 'component-list-social.css' | asset_url | stylesheet_tag }}

{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }

  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }

  .luxury-footer {
    background-color: {{ section.settings.bg_color }};
    color: {{ section.settings.text_color }};
    border-top: 1px solid rgba(0, 0, 0, 0.05);
    font-weight: 300;
  }

  .luxury-footer a {
    color: inherit;
    text-decoration: none;
    transition: opacity 0.3s;
  }

  .luxury-footer a:hover {
    opacity: 0.75;
  }

  .luxury-footer__content-top {
    display: grid;
    gap: 40px;
    grid-template-columns: 1fr;
    padding-bottom: 50px;
  }

  @media screen and (min-width: 750px) {
    .luxury-footer__content-top {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media screen and (min-width: 990px) {
    .luxury-footer__content-top {
      grid-template-columns: repeat(4, 1fr);
    }
  }

  .luxury-footer-block {
    display: flex;
    flex-direction: column;
    gap: 20px;
  }

  .luxury-footer-block__heading {
    font-size: 13px;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 1.5px;
    margin: 0;
  }

  /* List Menu */
  .luxury-footer-block__menu-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 12px;
    font-size: 14px;
  }

  /* Newsletter Block */
  .luxury-footer-block--newsletter {
    display: flex;
    flex-direction: column;
    gap: 15px;
  }

  .luxury-footer__newsletter-form {
    width: 100%;
    margin-top: 10px;
  }

  .luxury-footer__field-wrapper {
    position: relative;
    border-bottom: 1px solid rgba(0, 0, 0, 0.15);
    display: flex;
    align-items: center;
    padding-bottom: 8px;
    transition: border-bottom-color 0.3s;
  }

  .luxury-footer__field-wrapper:focus-within {
    border-bottom-color: {{ section.settings.text_color }};
  }

  .luxury-footer__input {
    background: transparent;
    border: none;
    width: 100%;
    font-size: 14px;
    color: inherit;
    outline: none;
    padding: 5px 0;
  }

  .luxury-footer__input::placeholder {
    color: inherit;
    opacity: 0.5;
  }

  .luxury-footer__submit-btn {
    background: transparent;
    border: none;
    color: inherit;
    cursor: pointer;
    padding: 0 5px;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .luxury-footer__submit-btn svg {
    width: 18px;
    height: 18px;
    fill: currentColor;
    transition: transform 0.3s;
  }

  .luxury-footer__submit-btn:hover svg {
    transform: translateX(4px);
  }

  /* Bottom Bar */
  .luxury-footer__content-bottom {
    border-top: 1px solid rgba(0, 0, 0, 0.05);
    padding-top: 40px;
    display: flex;
    flex-direction: column;
    gap: 30px;
  }

  @media screen and (min-width: 750px) {
    .luxury-footer__content-bottom {
      flex-direction: row;
      justify-content: space-between;
      align-items: center;
    }
  }

  .luxury-footer__bottom-left {
    display: flex;
    flex-direction: column;
    gap: 12px;
    font-size: 12px;
    opacity: 0.8;
  }

  .luxury-footer__policies {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-wrap: wrap;
    gap: 15px;
  }

  .luxury-footer__bottom-right {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 30px;
  }

  /* Localization Selectors */
  .luxury-footer__localization {
    display: flex;
    gap: 20px;
  }

  /* Payment Badges */
  .luxury-footer__payments {
    display: flex;
    gap: 8px;
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .luxury-footer__payments svg {
    width: 38px;
    height: 24px;
  }

  /* Collapsible Accordion (Mobile Viewport) */
  @media screen and (max-width: 749px) {
    .luxury-footer-block--menu {
      border-bottom: 1px solid rgba(0, 0, 0, 0.05);
      padding-bottom: 15px;
    }

    .luxury-footer-block__heading {
      cursor: pointer;
      display: flex;
      justify-content: space-between;
      align-items: center;
    }

    .luxury-footer-block__heading::after {
      content: '+';
      font-size: 18px;
      font-weight: 300;
      transition: transform 0.3s;
    }

    .luxury-footer-block--menu.is-active .luxury-footer-block__heading::after {
      content: '−';
    }

    .luxury-footer-block__menu-list {
      max-height: 0;
      overflow: hidden;
      transition: max-height 0.4s cubic-bezier(0.16, 1, 0.3, 1),
                  opacity 0.3s;
      opacity: 0;
      margin-top: 0;
    }

    .luxury-footer-block--menu.is-active .luxury-footer-block__menu-list {
      max-height: 350px;
      opacity: 1;
      margin-top: 15px;
    }
  }

  /* Social Icons */
  .luxury-footer__social-list {
    display: flex;
    gap: 15px;
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .luxury-footer__social-list svg {
    width: 18px;
    height: 18px;
    fill: currentColor;
  }
{%- endstyle -%}

<footer class="luxury-footer section-{{ section.id }}-padding">
  <div class="page-width">
    
    {%- comment -%} Top Layout Rows {%- endcomment -%}
    <div class="luxury-footer__content-top">
      
      {%- comment -%} Column Blocks loop {%- endcomment -%}
      {%- for block in section.blocks -%}
        {%- case block.type -%}
          
          {%- when 'brand_information' -%}
            <div class="luxury-footer-block" {{ block.shopify_attributes }}>
              {%- if block.settings.heading != blank -%}
                <h3 class="luxury-footer-block__heading">{{ block.settings.heading }}</h3>
              {%- endif -%}
              {%- if settings.brand_description != blank -%}
                <div class="luxury-footer-block__description text-body" style="font-size:14px; line-height:1.6; opacity:0.85;">
                  {{ settings.brand_description }}
                </div>
              {%- endif -%}
              {%- if block.settings.show_social -%}
                {%- comment -%} Renders native social icons snippet {%- endcomment -%}
                {%- render 'social-icons', class: 'luxury-footer__social-list' -%}
              {%- endif -%}
            </div>

          {%- when 'link_list' -%}
            <div class="luxury-footer-block luxury-footer-block--menu" {{ block.shopify_attributes }}>
              {%- if block.settings.heading != blank -%}
                <h3 class="luxury-footer-block__heading">{{ block.settings.heading }}</h3>
              {%- endif -%}
              {%- if block.settings.menu != blank -%}
                <ul class="luxury-footer-block__menu-list">
                  {%- for link in block.settings.menu.links -%}
                    <li>
                      <a href="{{ link.url }}">{{ link.title | escape }}</a>
                    </li>
                  {%- endfor -%}
                </ul>
              {%- endif -%}
            </div>

          {%- when 'text' -%}
            <div class="luxury-footer-block" {{ block.shopify_attributes }}>
              {%- if block.settings.heading != blank -%}
                <h3 class="luxury-footer-block__heading">{{ block.settings.heading }}</h3>
              {%- endif -%}
              {%- if block.settings.subtext != blank -%}
                <div class="luxury-footer-block__text text-body" style="font-size:14px; line-height:1.6; opacity:0.85;">
                  {{ block.settings.subtext }}
                </div>
              {%- endif -%}
            </div>

          {%- when 'image' -%}
            <div class="luxury-footer-block" {{ block.shopify_attributes }}>
              {%- if block.settings.image != blank -%}
                <div style="max-width: min(100%, {{ block.settings.image_width }}px);">
                  {{ block.settings.image | image_url: width: 600 | image_tag: loading: 'lazy', alt: block.settings.image.alt }}
                </div>
              {%- endif -%}
            </div>

        {%- endcase -%}
      {%- endfor -%}

      {%- comment -%} Newsletter Column (Always present on right if enabled) {%- endcomment -%}
      {%- if section.settings.newsletter_enable -%}
        <div class="luxury-footer-block luxury-footer-block--newsletter">
          {%- if section.settings.newsletter_heading != blank -%}
            <h3 class="luxury-footer-block__heading">{{ section.settings.newsletter_heading }}</h3>
          {%- endif -%}
          
          {%- form 'customer', id: 'ContactFooter', class: 'luxury-footer__newsletter-form' -%}
            <input type="hidden" name="contact[tags]" value="newsletter">
            <div class="luxury-footer__field-wrapper">
              <input
                id="NewsletterForm--{{ section.id }}"
                type="email"
                name="contact[email]"
                class="luxury-footer__input"
                value="{{ form.email }}"
                aria-required="true"
                autocorrect="off"
                autocapitalize="off"
                autocomplete="email"
                placeholder="Email Address"
                required
              >
              <button
                type="submit"
                class="luxury-footer__submit-btn"
                name="commit"
                id="Subscribe"
                aria-label="Subscribe"
              >
                <svg viewBox="0 0 24 24"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
              </button>
            </div>
            
            {%- if form.errors -%}
              <small class="form__message" id="ContactFooter-error" style="color:red; margin-top:5px; display:block;">
                {{ form.errors.translated_fields.email | capitalize }}
                {{ form.errors.messages.email }}
              </small>
            {%- endif -%}
            {%- if form.posted_successfully? -%}
              <h3 class="form__message" id="ContactFooter-success" tabindex="-1" autofocus style="font-size:12px; margin-top:8px; font-weight:400;">
                Thank you for subscribing.
              </h3>
            {%- endif -%}
          {%- endform -%}
        </div>
      {%- endif -%}

    </div>

    {%- comment -%} Bottom Footer details {%- endcomment -%}
    <div class="luxury-footer__content-bottom">
      
      <div class="luxury-footer__bottom-left">
        <div class="luxury-footer__copyright">
          &copy; {{ 'now' | date: '%Y' }} {{ shop.name | link_to: routes.root_url }}. All rights reserved.
        </div>
        {%- if section.settings.show_policy -%}
          <ul class="luxury-footer__policies">
            {%- for policy in shop.policies -%}
              {%- if policy != blank -%}
                <li>
                  <a href="{{ policy.url }}">{{ policy.title | escape }}</a>
                </li>
              {%- endif -%}
            {%- endfor -%}
          </ul>
        {%- endif -%}
      </div>

      <div class="luxury-footer__bottom-right">
        {%- comment -%} Localization (Country / Language Selectors) {%- endcomment -%}
        <div class="luxury-footer__localization isolate">
          {%- if section.settings.enable_country_selector and localization.available_countries.size > 1 -%}
            <localization-form>
              {%- form 'localization', id: 'FooterCountryForm', class: 'localization-form' -%}
                <div class="disclosure">
                  {%- render 'country-localization', localPosition: 'FooterCountry' -%}
                </div>
              {%- endform -%}
            </localization-form>
          {%- endif -%}

          {%- if section.settings.enable_language_selector and localization.available_languages.size > 1 -%}
            <localization-form>
              {%- form 'localization', id: 'FooterLanguageForm', class: 'localization-form' -%}
                <div class="disclosure">
                  {%- render 'language-localization', localPosition: 'FooterLanguage' -%}
                </div>
              {%- endform -%}
            </localization-form>
          {%- endif -%}
        </div>

        {%- comment -%} Payment Badges {%- endcomment -%}
        {%- if section.settings.payment_enable -%}
          <ul class="luxury-footer__payments" role="list">
            {%- for type in shop.enabled_payment_types -%}
              <li>
                {{ type | payment_type_svg_tag: class: 'icon icon--full-color' }}
              </li>
            {%- endfor -%}
          </ul>
        {%- endif -%}
      </div>

    </div>

  </div>
</footer>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    // Accordion menus under 749px mobile viewports
    const headings = document.querySelectorAll('.luxury-footer-block--menu .luxury-footer-block__heading');
    headings.forEach(heading => {
      heading.addEventListener('click', () => {
        if (window.innerWidth >= 750) return;
        const block = heading.closest('.luxury-footer-block--menu');
        if (block) {
          block.classList.toggle('is-active');
        }
      });
    });
  });
</script>

{% schema %}
{
  "name": "Luxury Footer",
  "tag": "section",
  "class": "section section-footer",
  "max_blocks": 4,
  "settings": [
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background Color",
      "default": "#fbfafa"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text Color",
      "default": "#121212"
    },
    {
      "type": "header",
      "content": "Newsletter Settings"
    },
    {
      "type": "checkbox",
      "id": "newsletter_enable",
      "default": true,
      "label": "Enable Newsletter Signup"
    },
    {
      "type": "inline_richtext",
      "id": "newsletter_heading",
      "default": "Sign up for updates",
      "label": "Newsletter Heading"
    },
    {
      "type": "header",
      "content": "Localization Selectors"
    },
    {
      "type": "checkbox",
      "id": "enable_country_selector",
      "default": true,
      "label": "Enable Country/Region Selector"
    },
    {
      "type": "checkbox",
      "id": "enable_language_selector",
      "default": true,
      "label": "Enable Language Selector"
    },
    {
      "type": "header",
      "content": "Payment Icons"
    },
    {
      "type": "checkbox",
      "id": "payment_enable",
      "default": true,
      "label": "Show Payment Icons"
    },
    {
      "type": "header",
      "content": "Policy Links"
    },
    {
      "type": "checkbox",
      "id": "show_policy",
      "default": true,
      "label": "Show Policy Links"
    },
    {
      "type": "header",
      "content": "Padding"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Padding Top",
      "default": 64
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Padding Bottom",
      "default": 36
    }
  ],
  "blocks": [
    {
      "type": "link_list",
      "name": "Menu Links",
      "settings": [
        {
          "type": "inline_richtext",
          "id": "heading",
          "default": "Quick links",
          "label": "Menu Heading"
        },
        {
          "type": "link_list",
          "id": "menu",
          "default": "footer",
          "label": "Select Menu"
        }
      ]
    },
    {
      "type": "brand_information",
      "name": "Brand Information",
      "settings": [
        {
          "type": "inline_richtext",
          "id": "heading",
          "default": "Vivikta Store",
          "label": "Headline"
        },
        {
          "type": "checkbox",
          "id": "show_social",
          "default": true,
          "label": "Show Social Media Links"
        }
      ]
    },
    {
      "type": "text",
      "name": "Rich Text Column",
      "settings": [
        {
          "type": "inline_richtext",
          "id": "heading",
          "default": "Our Story",
          "label": "Text Heading"
        },
        {
          "type": "richtext",
          "id": "subtext",
          "default": "<p>A boutique curating the finest aesthetic silhouettes and quality accessories.</p>",
          "label": "Text Description"
        }
      ]
    },
    {
      "type": "image",
      "name": "Image Column",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Select Image"
        },
        {
          "type": "range",
          "id": "image_width",
          "min": 50,
          "max": 550,
          "step": 5,
          "unit": "px",
          "label": "Image Width",
          "default": 100
        }
      ]
    }
  ],
  "default": {
    "blocks": [
      {
        "type": "brand_information"
      },
      {
        "type": "link_list"
      },
      {
        "type": "text"
      }
    ]
  }
}
{% endschema %}
