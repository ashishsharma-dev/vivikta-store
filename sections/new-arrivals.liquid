{%- liquid
  assign limit = section.settings.products_to_show
  assign collection = section.settings.collection
  assign products = collection.products
  assign total_products = products.size | at_most: limit

  comment
    Determine if slider should loop
  endcomment
  assign should_loop = false
  if section.settings.infinite_loop and total_products > 4
    assign should_loop = true
  endif

  comment
    Clones count
  endcomment
  assign clones_count = 4
-%}

{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }

  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }

  #NewArrivals-{{ section.id }} {
    background-color: {{ section.settings.bg_color }};
    --card-bg: {{ section.settings.card_bg }};
    --text-color: {{ section.settings.text_color }};
    --border-radius: {{ section.settings.card_border_radius }}px;
    --grid-gap: {{ section.settings.card_gap }}px;
    --sale-badge-bg: {{ section.settings.sale_badge_bg }};
    --sale-badge-text: {{ section.settings.sale_badge_text }};
    --new-badge-bg: {{ section.settings.new_badge_bg }};
    --new-badge-text: {{ section.settings.new_badge_text }};
  }

  .new-arrivals {
    width: 100%;
    overflow: hidden;
    box-sizing: border-box;
  }

  .new-arrivals__title-wrapper {
    margin-bottom: 40px;
    display: flex;
    justify-content: space-between;
    align-items: flex-end;
  }

  .new-arrivals__heading {
    margin: 0;
    font-weight: 300;
    text-transform: uppercase;
    letter-spacing: 2px;
  }

  /* Slider Layout */
  .new-arrivals-slider {
    position: relative;
    width: 100%;
  }

  .new-arrivals-slider__viewport {
    overflow: hidden;
    width: 100%;
    cursor: grab;
  }

  .new-arrivals-slider__viewport:active {
    cursor: grabbing;
  }

  .new-arrivals-slider__track {
    display: flex;
    transition: transform 0.5s cubic-bezier(0.25, 1, 0.5, 1);
    will-change: transform;
  }

  .new-arrivals-slider__slide {
    flex: 0 0 25%; /* Desktop: 4 items visible */
    box-sizing: border-box;
    padding: 0 calc(var(--grid-gap) / 2);
    user-select: none;
    -webkit-user-drag: none;
  }

  @media screen and (max-width: 990px) {
    .new-arrivals-slider__slide {
      flex: 0 0 50%; /* Tablet: 2 items visible */
    }
  }

  @media screen and (max-width: 749px) {
    .new-arrivals-slider__slide {
      flex: 0 0 83.33%; /* Mobile: 1.2 items visible */
    }
  }

  /* Navigation Arrows */
  .new-arrivals__nav {
    display: inline-flex;
    gap: 10px;
  }

  .new-arrivals__arrow {
    background: transparent;
    border: 1px solid rgba(0, 0, 0, 0.1);
    width: 44px;
    height: 44px;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    transition: border-color 0.3s, background-color 0.3s;
    color: inherit;
  }

  .new-arrivals__arrow:hover {
    border-color: var(--text-color);
    background-color: rgba(0, 0, 0, 0.02);
  }

  .new-arrivals__arrow svg {
    width: 16px;
    height: 16px;
    fill: currentColor;
  }

  /* Dot indicators */
  .new-arrivals-slider__dots {
    display: flex;
    justify-content: center;
    gap: 8px;
    margin-top: 30px;
  }

  .new-arrivals-slider__dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background-color: rgba(0, 0, 0, 0.15);
    border: none;
    padding: 0;
    cursor: pointer;
    transition: background-color 0.3s, transform 0.3s;
  }

  .new-arrivals-slider__dot.is-active {
    background-color: var(--text-color);
    transform: scale(1.3);
  }

  /* Product Card styling */
  .luxury-product-card {
    background-color: var(--card-bg);
    border-radius: var(--border-radius);
    overflow: hidden;
    position: relative;
    display: flex;
    flex-direction: column;
    height: 100%;
    box-shadow: 0 4px 15px rgba(0, 0, 0, 0.03);
    transition: transform 0.3s ease, box-shadow 0.3s ease;
  }

  .luxury-product-card:hover {
    transform: translateY(-5px);
    box-shadow: 0 10px 25px rgba(0, 0, 0, 0.07);
  }

  .luxury-product-card__media-wrapper {
    position: relative;
    width: 100%;
    aspect-ratio: 3/4;
    overflow: hidden;
    background-color: #f7f7f7;
  }

  .luxury-product-card__image-link {
    display: block;
    width: 100%;
    height: 100%;
  }

  .luxury-product-card__image-container {
    position: relative;
    width: 100%;
    height: 100%;
  }

  .luxury-product-card__image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.6s cubic-bezier(0.16, 1, 0.3, 1), opacity 0.6s ease;
  }

  .luxury-product-card__image--secondary {
    position: absolute;
    top: 0;
    left: 0;
    opacity: 0;
  }

  .luxury-product-card:hover .luxury-product-card__image--secondary {
    opacity: 1;
  }

  .luxury-product-card:hover .luxury-product-card__image--primary {
    transform: scale(1.05);
  }

  /* Badges */
  .luxury-product-card__badges {
    position: absolute;
    top: 15px;
    left: 15px;
    display: flex;
    flex-direction: column;
    gap: 6px;
    z-index: 3;
  }

  .luxury-badge {
    padding: 6px 12px;
    font-size: 10px;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 1px;
    border-radius: 2px;
  }

  .luxury-badge--sale {
    background-color: var(--sale-badge-bg);
    color: var(--sale-badge-text);
  }

  .luxury-badge--new {
    background-color: var(--new-badge-bg);
    color: var(--new-badge-text);
  }

  /* Wishlist Button */
  .luxury-product-card__wishlist {
    position: absolute;
    top: 15px;
    right: 15px;
    z-index: 3;
    background: #ffffff;
    border: none;
    width: 36px;
    height: 36px;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    box-shadow: 0 4px 10px rgba(0, 0, 0, 0.1);
    transition: transform 0.3s cubic-bezier(0.16, 1, 0.3, 1), background-color 0.3s;
  }

  .luxury-product-card__wishlist:hover {
    transform: scale(1.1);
  }

  .luxury-product-card__wishlist svg {
    width: 16px;
    height: 16px;
    fill: none;
    stroke: #121212;
    stroke-width: 2;
    transition: fill 0.3s, stroke 0.3s;
  }

  .luxury-product-card__wishlist.is-active svg {
    fill: #d32f2f;
    stroke: #d32f2f;
  }

  /* Quick Add Button overlay */
  .luxury-product-card__quick-add-wrapper {
    position: absolute;
    bottom: 0;
    left: 0;
    width: 100%;
    padding: 15px;
    box-sizing: border-box;
    z-index: 3;
    transform: translateY(100%);
    transition: transform 0.4s cubic-bezier(0.16, 1, 0.3, 1);
  }

  .luxury-product-card:hover .luxury-product-card__quick-add-wrapper {
    transform: translateY(0);
  }

  /* Add to Cart button styles */
  .luxury-quick-add-btn {
    width: 100%;
    background-color: #121212;
    color: #ffffff;
    border: none;
    padding: 12px 20px;
    font-size: 11px;
    font-weight: 500;
    letter-spacing: 1.5px;
    text-transform: uppercase;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 8px;
    transition: background-color 0.3s, transform 0.2s;
    box-shadow: 0 4px 15px rgba(0,0,0,0.2);
  }

  .luxury-quick-add-btn:hover {
    background-color: #333333;
  }

  .luxury-quick-add-btn:active {
    transform: scale(0.98);
  }

  /* Info */
  .luxury-product-card__info {
    padding: 20px;
    display: flex;
    flex-direction: column;
    flex-grow: 1;
    color: var(--text-color);
  }

  .luxury-product-card__vendor {
    font-size: 10px;
    text-transform: uppercase;
    letter-spacing: 1px;
    opacity: 0.6;
    margin-bottom: 6px;
  }

  .luxury-product-card__title {
    margin: 0 0 10px 0;
    font-size: 14px;
    font-weight: 400;
    line-height: 1.4;
  }

  .luxury-product-card__title a {
    color: inherit;
    text-decoration: none;
    transition: opacity 0.3s;
  }

  .luxury-product-card__title a:hover {
    opacity: 0.7;
  }

  /* Price */
  .luxury-product-card__price {
    display: flex;
    align-items: center;
    gap: 8px;
    margin-top: auto;
    font-size: 14px;
    font-weight: 500;
  }

  .luxury-price__compare {
    font-size: 12px;
    text-decoration: line-through;
    opacity: 0.5;
    font-weight: 400;
  }

  /* Rating */
  .luxury-product-card__rating {
    display: flex;
    align-items: center;
    gap: 5px;
    margin-bottom: 12px;
    font-size: 12px;
  }

  .rating-star {
    display: inline-block;
    width: 65px;
    height: 12px;
    background: linear-gradient(to right, #ffb800 calc(var(--rating) * 20%), #e5e5e5 calc(var(--rating) * 20%));
    -webkit-mask: url('data:image/svg+xml;utf8,<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24"><path d="M12 17.27L18.18 21l-1.64-7.03L22 9.24l-7.19-.61L12 2 9.19 8.63 2 9.24l5.46 4.73L5.82 21z"/></svg>') repeat-x;
    mask: url('data:image/svg+xml;utf8,<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24"><path d="M12 17.27L18.18 21l-1.64-7.03L22 9.24l-7.19-.61L12 2 9.19 8.63 2 9.24l5.46 4.73L5.82 21z"/></svg>') repeat-x;
    -webkit-mask-size: 13px 12px;
    mask-size: 13px 12px;
  }

  /* Color Swatches */
  .luxury-product-card__swatches {
    display: flex;
    flex-wrap: wrap;
    gap: 6px;
    margin-top: 12px;
  }

  .luxury-swatch {
    width: 14px;
    height: 14px;
    border-radius: 50%;
    border: 1px solid rgba(0, 0, 0, 0.15);
    padding: 0;
    cursor: pointer;
    position: relative;
    transition: transform 0.2s;
  }

  .luxury-swatch.is-active {
    transform: scale(1.2);
    box-shadow: 0 0 0 2px #ffffff, 0 0 0 3px #121212;
  }

  /* Spinner */
  .luxury-spinner {
    width: 12px;
    height: 12px;
    border: 2px solid rgba(255, 255, 255, 0.3);
    border-top-color: #ffffff;
    border-radius: 50%;
    animation: luxury-spin 0.6s linear infinite;
  }

  @keyframes luxury-spin {
    to { transform: rotate(360deg); }
  }

  .hidden {
    display: none !important;
  }
{%- endstyle -%}

<div id="NewArrivals-{{ section.id }}" class="new-arrivals section-{{ section.id }}-padding">
  <div class="page-width">
    
    <div class="new-arrivals__title-wrapper">
      <div>
        {%- if section.settings.heading != blank -%}
          <h2 class="new-arrivals__heading">{{ section.settings.heading }}</h2>
        {%- endif -%}
      </div>
      
      {%- if section.settings.show_arrows and total_products > 4 -%}
        <div class="new-arrivals__nav">
          <button class="new-arrivals__arrow new-arrivals__arrow--prev" aria-label="Previous slide">
            <svg viewBox="0 0 24 24"><path d="M15.41 7.41L14 6l-6 6 6 6 1.41-1.41L10.83 12z"/></svg>
          </button>
          <button class="new-arrivals__arrow new-arrivals__arrow--next" aria-label="Next slide">
            <svg viewBox="0 0 24 24"><path d="M10 6L8.59 7.41 13.17 12l-4.58 4.59L10 18l6-6z"/></svg>
          </button>
        </div>
      {%- endif -%}
    </div>

    <new-arrivals-slider class="new-arrivals-slider" 
                         data-infinite="{{ section.settings.infinite_loop }}" 
                         data-autoplay="{{ section.settings.autoplay }}" 
                         data-autoplay-speed="{{ section.settings.autoplay_speed }}"
                         data-mousewheel="{{ section.settings.mousewheel_support }}"
                         data-total-products="{{ total_products }}">
      
      <div class="new-arrivals-slider__viewport">
        <div class="new-arrivals-slider__track">
          
          {%- if collection != blank and total_products > 0 -%}
            
            {%- comment -%} Prepend Clones {%- endcomment -%}
            {%- if should_loop -%}
              {%- assign clones_offset = total_products | minus: clones_count -%}
              {%- for product in products limit: limit offset: clones_offset -%}
                <div class="new-arrivals-slider__slide cloned">
                  {% render 'luxury-product-card-item', product: product, section: section %}
                </div>
              {%- endfor -%}
            {%- endif -%}

            {%- comment -%} Original Slides {%- endcomment -%}
            {%- for product in products limit: limit -%}
              <div class="new-arrivals-slider__slide">
                {% render 'luxury-product-card-item', product: product, section: section %}
              </div>
            {%- endfor -%}

            {%- comment -%} Append Clones {%- endcomment -%}
            {%- if should_loop -%}
              {%- for product in products limit: clones_count -%}
                <div class="new-arrivals-slider__slide cloned">
                  {% render 'luxury-product-card-item', product: product, section: section %}
                </div>
              {%- endfor -%}
            {%- endif -%}

          {%- else -%}
            {%- comment -%} Onboarding placeholders if empty {%- endcomment -%}
            {%- for i in (1..6) -%}
              <div class="new-arrivals-slider__slide">
                <div class="luxury-product-card">
                  <div class="luxury-product-card__media-wrapper">
                    {{ 'product-' | append: i | placeholder_svg_tag: 'luxury-product-card__image placeholder-svg' }}
                  </div>
                  <div class="luxury-product-card__info">
                    <div class="luxury-product-card__vendor">Vendor</div>
                    <h3 class="luxury-product-card__title">
                      <a role="link" aria-disabled="true">Example Product {{ i }}</a>
                    </h3>
                    <div class="luxury-product-card__price">
                      <span class="luxury-price__current">$99.00</span>
                    </div>
                  </div>
                </div>
              </div>
            {%- endfor -%}
          {%- endif -%}

        </div>
      </div>

      {%- if section.settings.show_dots and total_products > 4 -%}
        <div class="new-arrivals-slider__dots"></div>
      {%- endif -%}

    </new-arrivals-slider>

  </div>
</div>

{%- comment -%} Product Card Render Script & Form Submission {%- endcomment -%}
<script>
  if (!customElements.get('new-arrivals-slider')) {
    customElements.define('new-arrivals-slider', class NewArrivalsSlider extends HTMLElement {
      constructor() {
        super();
        this.track = null;
        this.viewport = null;
        this.slides = [];
        
        // Options
        this.infinite = false;
        this.autoplay = false;
        this.autoplaySpeed = 3000;
        this.mousewheel = false;
        
        // Navigation
        this.dotsContainer = null;
        this.btnPrev = null;
        this.btnNext = null;

        // Slider states
        this.currentIndex = 0;
        this.startIndex = 0;
        this.totalOriginal = 0;
        this.totalSlides = 0;
        this.visibleSlides = 4;
        
        // Interaction dragging states
        this.isDragging = false;
        this.startX = 0;
        this.currentTranslate = 0;
        this.prevTranslate = 0;
        this.dragged = false;
        
        this.autoplayTimer = null;
        this.wheelDebounce = false;
      }

      connectedCallback() {
        this.track = this.querySelector('.new-arrivals-slider__track');
        this.viewport = this.querySelector('.new-arrivals-slider__viewport');
        this.slides = Array.from(this.track.querySelectorAll('.new-arrivals-slider__slide'));
        this.btnPrev = this.parentElement.querySelector('.new-arrivals-slider__arrow--prev');
        this.btnNext = this.parentElement.querySelector('.new-arrivals-slider__arrow--next');
        this.dotsContainer = this.querySelector('.new-arrivals-slider__dots');

        this.infinite = this.dataset.infinite === 'true';
        this.autoplay = this.dataset.autoplay === 'true';
        this.autoplaySpeed = parseInt(this.dataset.autoplaySpeed) || 3000;
        this.mousewheel = this.dataset.mousewheel === 'true';
        this.totalOriginal = parseInt(this.dataset.totalProducts) || 0;
        this.totalSlides = this.slides.length;

        if (this.totalSlides === 0 || this.totalOriginal === 0) return;

        this.updateVisibleSlidesCount();
        this.initSlider();
      }

      disconnectedCallback() {
        this.stopAutoplay();
        window.removeEventListener('resize', this.resizeHandler);
      }

      updateVisibleSlidesCount() {
        const width = window.innerWidth;
        if (width >= 990) {
          this.visibleSlides = 4;
        } else if (width >= 750) {
          this.visibleSlides = 2;
        } else {
          this.visibleSlides = 1.2;
        }
      }

      initSlider() {
        this.startIndex = this.infinite && this.totalOriginal > 4 ? 4 : 0;
        this.currentIndex = this.startIndex;

        // Positioning
        this.setTrackPosition(-this.currentIndex * this.getSlideWidth());

        // Event hooks
        this.initEvents();
        this.initDots();
        this.updateDots();
        this.startAutoplay();
      }

      initEvents() {
        // Arrows
        if (this.btnPrev) this.btnPrev.addEventListener('click', () => this.slidePrev());
        if (this.btnNext) this.btnNext.addEventListener('click', () => this.slideNext());

        // Drag handlers
        this.viewport.addEventListener('mousedown', (e) => this.dragStart(e));
        this.viewport.addEventListener('mousemove', (e) => this.dragMove(e));
        this.viewport.addEventListener('mouseup', () => this.dragEnd());
        this.viewport.addEventListener('mouseleave', () => { if (this.isDragging) this.dragEnd(); });

        this.viewport.addEventListener('touchstart', (e) => this.dragStart(e), { passive: true });
        this.viewport.addEventListener('touchmove', (e) => this.dragMove(e), { passive: true });
        this.viewport.addEventListener('touchend', () => this.dragEnd());

        // Infinite loop snapping
        this.track.addEventListener('transitionend', () => this.handleTransitionEnd());

        // Resize
        this.resizeHandler = () => {
          this.updateVisibleSlidesCount();
          this.disableTransition();
          this.setTrackPosition(-this.currentIndex * this.getSlideWidth());
        };
        window.addEventListener('resize', this.resizeHandler);

        // Mousewheel hijacking
        if (this.mousewheel) {
          this.addEventListener('wheel', (e) => {
            if (Math.abs(e.deltaY) > 20 && !this.wheelDebounce) {
              e.preventDefault();
              this.wheelDebounce = true;
              if (e.deltaY > 0) {
                this.slideNext();
              } else {
                this.slidePrev();
              }
              setTimeout(() => { this.wheelDebounce = false; }, 400);
            }
          }, { passive: false });
        }

        // Swatch handling
        this.initSwatches();

        // Wishlist handling
        this.initWishlist();

        // AJAX Add to Cart
        this.initQuickAdd();
      }

      getSlideWidth() {
        return this.slides[0].offsetWidth;
      }

      setTrackPosition(translate) {
        this.currentTranslate = translate;
        this.track.style.transform = `translate3d(${translate}px, 0, 0)`;
      }

      enableTransition() {
        this.track.style.transition = 'transform 0.5s cubic-bezier(0.25, 1, 0.5, 1)';
      }

      disableTransition() {
        this.track.style.transition = 'none';
      }

      slideNext() {
        this.stopAutoplay();
        this.currentIndex++;
        this.enableTransition();
        this.setTrackPosition(-this.currentIndex * this.getSlideWidth());
        this.updateDots();
        this.startAutoplay();
      }

      slidePrev() {
        this.stopAutoplay();
        this.currentIndex--;
        this.enableTransition();
        this.setTrackPosition(-this.currentIndex * this.getSlideWidth());
        this.updateDots();
        this.startAutoplay();
      }

      handleTransitionEnd() {
        if (!this.infinite || this.totalOriginal <= 4) return;

        if (this.currentIndex >= this.startIndex + this.totalOriginal) {
          this.disableTransition();
          this.currentIndex = this.currentIndex - this.totalOriginal;
          this.setTrackPosition(-this.currentIndex * this.getSlideWidth());
        } else if (this.currentIndex < this.startIndex) {
          this.disableTransition();
          this.currentIndex = this.currentIndex + this.totalOriginal;
          this.setTrackPosition(-this.currentIndex * this.getSlideWidth());
        }
      }

      // Drag mechanics
      dragStart(e) {
        this.stopAutoplay();
        this.isDragging = true;
        this.dragged = false;
        this.startX = e.clientX || e.touches[0].clientX;
        this.prevTranslate = -this.currentIndex * this.getSlideWidth();
        this.disableTransition();
      }

      dragMove(e) {
        if (!this.isDragging) return;
        this.dragged = true;
        const currentX = e.clientX || (e.touches && e.touches[0].clientX);
        const deltaX = currentX - this.startX;
        this.setTrackPosition(this.prevTranslate + deltaX);
      }

      dragEnd() {
        if (!this.isDragging) return;
        this.isDragging = false;
        
        const dragDistance = this.currentTranslate - this.prevTranslate;
        
        if (dragDistance < -60) {
          this.slideNext();
        } else if (dragDistance > 60) {
          this.slidePrev();
        } else {
          // Snap back
          this.enableTransition();
          this.setTrackPosition(-this.currentIndex * this.getSlideWidth());
        }
        
        this.startAutoplay();
      }

      // Autoplay
      startAutoplay() {
        if (!this.autoplay) return;
        this.stopAutoplay();
        this.autoplayTimer = setInterval(() => {
          this.currentIndex++;
          this.enableTransition();
          this.setTrackPosition(-this.currentIndex * this.getSlideWidth());
          this.updateDots();
        }, this.autoplaySpeed);
      }

      stopAutoplay() {
        if (this.autoplayTimer) {
          clearInterval(this.autoplayTimer);
          this.autoplayTimer = null;
        }
      }

      // Dots indicators
      initDots() {
        if (!this.dotsContainer) return;
        this.dotsContainer.innerHTML = '';
        for (let i = 0; i < this.totalOriginal; i++) {
          const dot = document.createElement('button');
          dot.className = 'new-arrivals-slider__dot';
          dot.ariaLabel = `Go to slide ${i + 1}`;
          dot.addEventListener('click', () => {
            this.stopAutoplay();
            this.currentIndex = this.startIndex + i;
            this.enableTransition();
            this.setTrackPosition(-this.currentIndex * this.getSlideWidth());
            this.updateDots();
            this.startAutoplay();
          });
          this.dotsContainer.appendChild(dot);
        }
      }

      updateDots() {
        if (!this.dotsContainer) return;
        const dots = this.dotsContainer.querySelectorAll('.new-arrivals-slider__dot');
        dots.forEach(dot => dot.classList.remove('is-active'));
        
        let relativeIndex = (this.currentIndex - this.startIndex) % this.totalOriginal;
        if (relativeIndex < 0) relativeIndex += this.totalOriginal;
        
        if (dots[relativeIndex]) {
          dots[relativeIndex].classList.add('is-active');
        }
      }

      // Interactive Color Swatches
      initSwatches() {
        this.querySelectorAll('.luxury-swatch').forEach(swatch => {
          swatch.addEventListener('click', (e) => {
            e.preventDefault();
            const card = swatch.closest('.luxury-product-card');
            if (!card) return;

            // Swatch highlight toggle
            swatch.parentElement.querySelectorAll('.luxury-swatch').forEach(s => s.classList.remove('is-active'));
            swatch.classList.add('is-active');

            // Swap variant image
            const variantImgSrc = swatch.dataset.variantImage;
            const primaryImg = card.querySelector('.luxury-product-card__image--primary');
            if (variantImgSrc && primaryImg) {
              primaryImg.src = variantImgSrc;
              primaryImg.srcset = ''; // clear to force loading new src
            }

            // Swap price
            const priceCurrent = card.querySelector('.luxury-price__current');
            const priceCompare = card.querySelector('.luxury-price__compare');
            if (priceCurrent && swatch.dataset.variantPrice) {
              priceCurrent.textContent = swatch.dataset.variantPrice;
            }
            if (priceCompare) {
              if (swatch.dataset.variantComparePrice) {
                priceCompare.textContent = swatch.dataset.variantComparePrice;
                priceCompare.classList.remove('hidden');
              } else {
                priceCompare.classList.add('hidden');
              }
            }

            // Update targeted variant ID for quick add
            const quickAddBtn = card.querySelector('.luxury-quick-add-btn');
            if (quickAddBtn && swatch.dataset.variantId) {
              quickAddBtn.dataset.variantId = swatch.dataset.variantId;
            }
            card.dataset.variantId = swatch.dataset.variantId;
          });
        });
      }

      // Wishlist Persistent Storage logic
      initWishlist() {
        const WISHLIST_KEY = 'vivikta_wishlist';
        let wishlist = JSON.parse(localStorage.getItem(WISHLIST_KEY)) || [];

        // Check initial state
        this.querySelectorAll('.luxury-product-card__wishlist').forEach(btn => {
          const handle = btn.dataset.productHandle;
          if (wishlist.includes(handle)) {
            btn.classList.add('is-active');
          }

          btn.addEventListener('click', (e) => {
            e.preventDefault();
            wishlist = JSON.parse(localStorage.getItem(WISHLIST_KEY)) || [];
            
            if (wishlist.includes(handle)) {
              wishlist = wishlist.filter(h => h !== handle);
              btn.classList.remove('is-active');
            } else {
              wishlist.push(handle);
              btn.classList.add('is-active');
            }
            
            localStorage.setItem(WISHLIST_KEY, JSON.stringify(wishlist));
          });
        });
      }

      // AJAX Add to Cart
      initQuickAdd() {
        this.querySelectorAll('.luxury-quick-add-btn').forEach(btn => {
          if (btn.classList.contains('luxury-quick-add-btn--select')) {
            // Complex variant redirects
            btn.addEventListener('click', () => {
              window.location.href = btn.dataset.productUrl;
            });
            return;
          }

          btn.addEventListener('click', (e) => {
            e.preventDefault();
            const variantId = btn.dataset.variantId;
            const spinner = btn.querySelector('.luxury-spinner');
            const label = btn.querySelector('span');

            if (!variantId) return;

            // Loading state
            if (spinner) spinner.classList.remove('hidden');
            if (label) label.textContent = 'Adding...';
            btn.disabled = true;

            fetch('/cart/add.js', {
              method: 'POST',
              headers: { 'Content-Type': 'application/json' },
              body: JSON.stringify({ items: [{ id: variantId, quantity: 1 }] })
            })
            .then(response => {
              if (!response.ok) throw new Error('Failed to add');
              return response.json();
            })
            .then(data => {
              // Update drawer/cart
              document.dispatchEvent(new CustomEvent('cart:updated', { detail: { cart: data } }));
              
              const cartDrawer = document.querySelector('cart-drawer');
              if (cartDrawer && typeof cartDrawer.renderContents === 'function') {
                cartDrawer.renderContents(data);
              } else {
                const cartNotification = document.querySelector('cart-notification');
                if (cartNotification && typeof cartNotification.renderContents === 'function') {
                  cartNotification.renderContents(data);
                } else {
                  // Fallback: manually update cart bubbles
                  fetch('/cart.js')
                    .then(res => res.json())
                    .then(cart => {
                      const bubbles = document.querySelectorAll('.cart-count-bubble span:first-child');
                      bubbles.forEach(b => b.textContent = cart.item_count);
                      
                      const wrappers = document.querySelectorAll('.cart-count-bubble');
                      wrappers.forEach(w => w.classList.remove('hidden'));
                    });
                }
              }
              
              if (label) label.textContent = 'Added!';
              setTimeout(() => {
                if (label) label.textContent = 'Quick Add';
                btn.disabled = false;
              }, 2000);
            })
            .catch(error => {
              console.error(error);
              if (label) label.textContent = 'Error';
              setTimeout(() => {
                if (label) label.textContent = 'Quick Add';
                btn.disabled = false;
              }, 2000);
            })
            .finally(() => {
              if (spinner) spinner.classList.add('hidden');
            });
          });
        });
      }
    });
  }
</script>

