          "unit": "%",
          "label": "Hotspot Horizontal Position (X)",
          "default": 50
        },
        {
          "type": "range",
          "id": "y_pos",
          "min": 0,
          "max": 100,
          "step": 1,
          "unit": "%",
          "label": "Hotspot Vertical Position (Y)",
          "default": 50
        }
      ]
    }
  ],
  "presets": [
    {
