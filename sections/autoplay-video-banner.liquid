{%- liquid
  # Image loading optimization
  assign loading_attr = 'lazy'
  assign fetch_priority = 'auto'
  if section.settings.preload_poster
    assign loading_attr = 'eager'
    assign fetch_priority = 'high'
  endif
-%}

{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }

  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }

  #VideoBanner-{{ section.id }} {
    background-color: {{ section.settings.bg_color }};
    --text-color: {{ section.settings.text_color }};
    --overlay-color: {{ section.settings.overlay_color }};
    --overlay-opacity: {{ section.settings.overlay_opacity | divided_by: 100.0 }};
    --desktop-height: {% if section.settings.desktop_height == '100vh' %}100vh{% else %}{{ section.settings.custom_desktop_height }}vh{% endif %};
    --mobile-height: {{ section.settings.custom_mobile_height }}vh;
    --heading-size-desktop: {{ section.settings.heading_size_desktop }}px;
    --heading-size-mobile: {{ section.settings.heading_size_mobile }}px;
    --content-max-width: {{ section.settings.content_max_width }}px;
  }

  .video-banner {
    position: relative;
    width: 100%;
    height: var(--desktop-height);
    overflow: hidden;
    display: flex;
    align-items: center;
    box-sizing: border-box;
  }

  @media screen and (max-width: 749px) {
    .video-banner {
      height: var(--mobile-height);
    }
  }

  /* Media Layers */
  .video-banner__media-wrapper {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    z-index: 1;
    pointer-events: none;
  }

  .video-banner__poster,
  .video-banner__video,
  .video-banner__iframe-container {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .video-banner__poster {
    z-index: 2;
    transition: opacity 1s ease-in-out;
  }

  .video-banner.is-playing .video-banner__poster {
    opacity: 0;
    pointer-events: none;
  }

  .video-banner__video {
    z-index: 3;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .video-banner__iframe-container {
    z-index: 3;
    pointer-events: none;
  }

  .video-banner__iframe-container iframe {
    position: absolute;
    top: 50%;
    left: 50%;
    width: 100vw;
    height: 56.25vw; /* 16:9 ratio */
    min-height: 100%;
    min-width: 177.77%; /* 16:9 ratio */
    transform: translate(-50%, -50%);
    pointer-events: none;
    border: none;
  }

  /* Overlay */
  .video-banner__overlay {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background-color: var(--overlay-color);
    opacity: var(--overlay-opacity);
    z-index: 4;
  }

  /* Content Overlay */
  .video-banner__content-container {
    position: relative;
    z-index: 5;
    width: 100%;
    height: 100%;
    display: flex;
    box-sizing: border-box;
    align-items: center;
  }

  .video-banner--align-left .video-banner__content-container {
    justify-content: flex-start;
    text-align: left;
  }
  .video-banner--align-center .video-banner__content-container {
    justify-content: center;
    text-align: center;
  }
  .video-banner--align-right .video-banner__content-container {
    justify-content: flex-end;
    text-align: right;
  }

  .video-banner__content {
    max-width: var(--content-max-width);
    width: 100%;
    color: var(--text-color);
  }

  .video-banner__heading {
    margin: 0 0 20px 0;
    font-size: var(--heading-size-mobile);
    font-weight: 300;
    text-transform: uppercase;
    letter-spacing: 2px;
    line-height: 1.15;
  }

  @media screen and (min-width: 750px) {
    .video-banner__heading {
      font-size: var(--heading-size-desktop);
    }
  }

  .video-banner__subheading {
    font-size: 16px;
    font-weight: 300;
    line-height: 1.6;
    margin: 0 0 35px 0;
    opacity: 0.9;
  }

  /* Buttons */
  .video-banner-btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 16px 45px;
    font-size: 12px;
    font-weight: 500;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    text-decoration: none;
    border: 1px solid var(--text-color);
    background-color: var(--text-color);
    color: var(--overlay-color);
    transition: all 0.4s cubic-bezier(0.16, 1, 0.3, 1);
    cursor: pointer;
  }

  .video-banner-btn:hover {
    background-color: transparent;
    color: var(--text-color);
    transform: translateY(-2px);
  }

  /* Play Pause Toggle Button overlay */
  .video-banner__controls {
    position: absolute;
    bottom: 30px;
    right: 30px;
    z-index: 6;
  }

  @media screen and (max-width: 749px) {
    .video-banner__controls {
      bottom: 20px;
      right: 20px;
    }
  }

  .video-banner__play-toggle {
    background: rgba(0, 0, 0, 0.25);
    border: 1px solid rgba(255, 255, 255, 0.3);
    backdrop-filter: blur(5px);
    width: 44px;
    height: 44px;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    color: #ffffff;
    transition: background-color 0.3s, transform 0.2s;
    padding: 0;
  }

  .video-banner__play-toggle:hover {
    background: rgba(0, 0, 0, 0.45);
    transform: scale(1.05);
  }

  .video-banner__play-toggle svg {
    width: 14px;
    height: 14px;
    fill: currentColor;
  }

  .video-banner__play-toggle .icon-play {
    margin-left: 2px;
  }

  .video-banner__play-toggle.is-paused .icon-pause {
    display: none;
  }

  .video-banner__play-toggle:not(.is-paused) .icon-play {
    display: none;
  }
{%- endstyle -%}

<video-banner 
  id="VideoBanner-{{ section.id }}" 
  class="video-banner video-banner--align-{{ section.settings.content_alignment }} section-{{ section.id }}-padding"
  data-section-id="{{ section.id }}"
  data-video-source="{{ section.settings.video_source }}"
  data-desktop-video-url="{{ section.settings.desktop_video_url | default: section.settings.shopify_desktop_video.sources[0].url }}"
  data-mobile-video-url="{{ section.settings.mobile_video_url | default: section.settings.shopify_mobile_video.sources[0].url }}"
  data-youtube-vimeo-url="{{ section.settings.youtube_vimeo_url }}"
  data-loop="{{ section.settings.loop_video }}"
  data-mute="{{ section.settings.mute_video }}"
>
  
  {%- comment -%} Background Media Wrapper {%- endcomment -%}
  <div class="video-banner__media-wrapper">
    
    {%- comment -%} Poster Image fallback {%- endcomment -%}
    {%- if section.settings.poster_image != blank -%}
      {{ section.settings.poster_image | image_url: width: 2500 | image_tag: 
        loading: loading_attr, 
        fetchpriority: fetch_priority, 
        class: 'video-banner__poster', 
        widths: '375, 550, 750, 990, 1200, 1500, 2000, 2500', 
        alt: section.settings.heading 
      }}
    {%- else -%}
      {{ 'lifestyle-2' | placeholder_svg_tag: 'video-banner__poster placeholder-svg' }}
    {%- endif -%}

    {%- comment -%} Media targets injected dynamically by JS Web Component {%- endcomment -%}
    
  </div>

  {%- comment -%} Background Overlay Mask {%- endcomment -%}
  <div class="video-banner__overlay"></div>

  {%- comment -%} Content Overlay {%- endcomment -%}
  <div class="video-banner__content-container page-width">
    <div class="video-banner__content">
      {%- if section.settings.heading != blank -%}
        <h2 class="video-banner__heading">{{ section.settings.heading }}</h2>
      {%- endif -%}
      {%- if section.settings.subheading != blank -%}
        <div class="video-banner__subheading">{{ section.settings.subheading }}</div>
      {%- endif -%}
      {%- if section.settings.cta_label != blank -%}
        <a href="{{ section.settings.cta_link | default: '#' }}" class="video-banner-btn" {% if section.settings.cta_link == blank %}aria-disabled="true"{% endif %}>
          {{ section.settings.cta_label }}
        </a>
      {%- endif -%}
    </div>
  </div>

  {%- comment -%} Play / Pause Control Overlay {%- endcomment -%}
  <div class="video-banner__controls">
    <button class="video-banner__play-toggle" aria-label="Toggle video playback">
      {%- comment -%} Pause Icon {%- endcomment -%}
      <svg viewBox="0 0 24 24" class="icon-pause"><path d="M6 19h4V5H6v14zm8-14v14h4V5h-4z"/></svg>
      {%- comment -%} Play Icon {%- endcomment -%}
      <svg viewBox="0 0 24 24" class="icon-play"><path d="M8 5v14l11-7z"/></svg>
    </button>
  </div>

</video-banner>

<script>
  if (!customElements.get('video-banner')) {
    customElements.define('video-banner', class VideoBanner extends HTMLElement {
      constructor() {
        super();
        this.observer = null;
        this.mediaWrapper = null;
        this.playToggleBtn = null;
        this.videoEl = null;
        this.iframeEl = null;
        this.isPlaying = false;
        
        // Settings variables
        this.source = 'shopify';
        this.desktopVideoUrl = '';
        this.mobileVideoUrl = '';
        this.thirdPartyUrl = '';
        this.loop = true;
        this.mute = true;
      }

      connectedCallback() {
        this.mediaWrapper = this.querySelector('.video-banner__media-wrapper');
        this.playToggleBtn = this.querySelector('.video-banner__play-toggle');

        this.source = this.dataset.videoSource;
        this.desktopVideoUrl = this.dataset.desktopVideoUrl;
        this.mobileVideoUrl = this.dataset.mobileVideoUrl;
        this.thirdPartyUrl = this.dataset.youtubeVimeoUrl;
        this.loop = this.dataset.loop === 'true';
        this.mute = this.dataset.mute === 'true';

        // Play/Pause button binder
        if (this.playToggleBtn) {
          this.playToggleBtn.addEventListener('click', (e) => {
            e.preventDefault();
            this.togglePlayback();
          });
        }

        // Initialize lazy loading observer
        this.initLazyLoader();

        // Shopify theme customizer events reload compatibility
        this.sectionLoadHandler = (event) => {
          if (event.detail.sectionId === this.dataset.sectionId) {
            this.destroyVideo();
            this.initVideo();
          }
        };
        document.addEventListener('shopify:section:load', this.sectionLoadHandler);
      }

      disconnectedCallback() {
        if (this.observer) this.observer.disconnect();
        document.removeEventListener('shopify:section:load', this.sectionLoadHandler);
        this.destroyVideo();
      }

      initLazyLoader() {
        // If preload poster is selected or section sits at the top, initialize immediately
        if (this.querySelector('[fetchpriority="high"]')) {
          this.initVideo();
          return;
        }

        this.observer = new IntersectionObserver((entries) => {
          entries.forEach(entry => {
            if (entry.isIntersecting) {
              this.initVideo();
              this.observer.unobserve(this);
            }
          });
        }, {
          rootMargin: '0px 0px 200px 0px',
          threshold: 0.05
        });

        this.observer.observe(this);
      }

      initVideo() {
        if (this.source === 'shopify' || this.source === 'mp4') {
          this.renderNativeVideo();
        } else if (this.source === 'youtube' || this.source === 'vimeo') {
          this.renderThirdPartyEmbed();
        }
      }

      renderNativeVideo() {
        const video = document.createElement('video');
        video.className = 'video-banner__video';
        video.autoplay = true;
        video.playsInline = true;
        if (this.loop) video.loop = true;
        if (this.mute) video.muted = true;

        // Choose source URL responsive width
        const width = window.innerWidth;
        const activeUrl = (width < 750 && this.mobileVideoUrl) ? this.mobileVideoUrl : this.desktopVideoUrl;
        
        if (!activeUrl) return;

        video.src = activeUrl;
        this.mediaWrapper.appendChild(video);
        this.videoEl = video;

        video.addEventListener('play', () => this.setPlaybackState(true));
        video.addEventListener('pause', () => this.setPlaybackState(false));

        // Auto play trigger
        video.play().catch(err => {
          console.log('Autoplay blocked by browser. Muting to override.', err);
          video.muted = true;
          video.play();
        });
      }

      renderThirdPartyEmbed() {
        const url = this.thirdPartyUrl.trim();
        if (!url) return;

        const iframeContainer = document.createElement('div');
        iframeContainer.className = 'video-banner__iframe-container';
        
        const iframe = document.createElement('iframe');
        iframe.allow = 'autoplay; encrypted-media';

        let embedUrl = '';

        if (this.source === 'youtube') {
          const ytId = this.extractYouTubeId(url);
          if (!ytId) return;
          
          embedUrl = `https://www.youtube.com/embed/${ytId}?autoplay=1&controls=0&showinfo=0&rel=0&enablejsapi=1`;
          if (this.loop) embedUrl += `&loop=1&playlist=${ytId}`;
          if (this.mute) embedUrl += '&mute=1';
        } else if (this.source === 'vimeo') {
          const vimeoId = this.extractVimeoId(url);
          if (!vimeoId) return;

          embedUrl = `https://player.vimeo.com/video/${vimeoId}?autoplay=1&background=1&controls=0&responsive=1`;
          if (this.loop) embedUrl += '&loop=1';
          if (this.mute) embedUrl += '&muted=1';
        }

        iframe.src = embedUrl;
        iframeContainer.appendChild(iframe);
        this.mediaWrapper.appendChild(iframeContainer);
        this.iframeEl = iframe;

        // Simulate autoplay active
        this.setPlaybackState(true);
      }

      togglePlayback() {
        if (this.videoEl) {
          if (this.isPlaying) {
            this.videoEl.pause();
          } else {
            this.videoEl.play();
          }
        } else if (this.iframeEl) {
          const win = this.iframeEl.contentWindow;
          if (this.source === 'youtube') {
            if (this.isPlaying) {
              win.postMessage('{"event":"command","func":"pauseVideo","args":""}', '*');
              this.setPlaybackState(false);
            } else {
              win.postMessage('{"event":"command","func":"playVideo","args":""}', '*');
              this.setPlaybackState(true);
            }
          } else if (this.source === 'vimeo') {
            if (this.isPlaying) {
              win.postMessage('{"method":"pause"}', '*');
              this.setPlaybackState(false);
            } else {
              win.postMessage('{"method":"play"}', '*');
              this.setPlaybackState(true);
            }
          }
        }
      }

      setPlaybackState(isPlaying) {
        this.isPlaying = isPlaying;
        if (isPlaying) {
          this.classList.add('is-playing');
          if (this.playToggleBtn) this.playToggleBtn.classList.remove('is-paused');
        } else {
          this.classList.remove('is-playing');
          if (this.playToggleBtn) this.playToggleBtn.classList.add('is-paused');
        }
      }

      destroyVideo() {
        if (this.videoEl) {
          this.videoEl.remove();
          this.videoEl = null;
        }
        const iframeContainer = this.querySelector('.video-banner__iframe-container');
        if (iframeContainer) {
          iframeContainer.remove();
          this.iframeEl = null;
        }
        this.setPlaybackState(false);
      }

      extractYouTubeId(url) {
        const regExp = /^.*(youtu.be\/|v\/|u\/\w\/|embed\/|watch\?v=|\&v=)([^#\&\?]*).*/;
        const match = url.match(regExp);
        return (match && match[2].length === 11) ? match[2] : null;
      }

      extractVimeoId(url) {
        const regExp = /(vimeo\.com\/|video\/)(\d+)/;
        const match = url.match(regExp);
        return match ? match[2] : null;
      }
    });
  }
</script>

{% schema %}
{
  "name": "Autoplay Video Banner",
  "tag": "section",
  "class": "section section-autoplay-video-banner",
  "disabled_on": {
    "groups": ["header", "footer"]
  },
  "settings": [
    {
      "type": "header",
      "content": "Video Background Source"
    },
    {
      "type": "select",
      "id": "video_source",
      "label": "Video Source Provider",
      "options": [
        { "value": "shopify", "label": "Shopify Hosted Video Files" },
        { "value": "mp4", "label": "Raw MP4 Fallback URLs" },
        { "value": "youtube", "label": "YouTube Video" },
        { "value": "vimeo", "label": "Vimeo Video" }
      ],
      "default": "shopify"
    },
    {
      "type": "video",
      "id": "shopify_desktop_video",
      "label": "Shopify Desktop Hosted Video"
    },
    {
      "type": "video",
      "id": "shopify_mobile_video",
      "label": "Shopify Mobile Hosted Video (Optional)"
    },
    {
      "type": "text",
      "id": "desktop_video_url",
      "label": "Raw Desktop MP4 URL",
      "info": "Paste a direct link to an uploaded MP4 file if not using Shopify Hosted Video setting above."
    },
    {
      "type": "text",
      "id": "mobile_video_url",
      "label": "Raw Mobile MP4 URL (Optional)"
    },
    {
      "type": "text",
      "id": "youtube_vimeo_url",
      "label": "YouTube or Vimeo Video Link",
      "info": "E.g. https://www.youtube.com/watch?v=dQw4w9WgXcQ"
    },
    {
      "type": "image_picker",
      "id": "poster_image",
      "label": "Fallback Poster Image",
      "info": "Crucial: Displays before the video plays or as a static banner if loading third-party embeds."
    },
    {
      "type": "header",
      "content": "Playback Settings"
    },
    {
      "type": "checkbox",
      "id": "loop_video",
      "label": "Infinite Loop Video",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "mute_video",
      "label": "Mute Video on Load",
      "default": true,
      "info": "Note: Browsers block autoplay of unmuted videos."
    },
    {
      "type": "checkbox",
      "id": "preload_poster",
      "label": "Preload Fallback Poster",
      "default": true,
      "info": "For LCP optimization: Choose this if this section is the top banner on your homepage."
    },
    {
      "type": "header",
      "content": "Overlay & Styling"
    },
    {
      "type": "color",
      "id": "overlay_color",
      "label": "Overlay Mask Color",
      "default": "#000000"
    },
    {
      "type": "range",
      "id": "overlay_opacity",
      "min": 0,
      "max": 100,
      "step": 5,
      "unit": "%",
      "label": "Overlay Opacity",
      "default": 35
    },
    {
      "type": "select",
      "id": "desktop_height",
      "label": "Desktop Banner Height",
      "options": [
        { "value": "100vh", "label": "Full Screen (100vh)" },
        { "value": "custom", "label": "Custom Height (Defined Below)" }
      ],
      "default": "100vh"
    },
    {
      "type": "range",
      "id": "custom_desktop_height",
      "min": 30,
      "max": 100,
      "step": 5,
      "unit": "vh",
      "label": "Custom Desktop Height",
      "default": 90
    },
    {
      "type": "range",
      "id": "custom_mobile_height",
      "min": 30,
      "max": 100,
      "step": 5,
      "unit": "vh",
      "label": "Custom Mobile Height (Below 749px)",
      "default": 70
    },
    {
      "type": "header",
      "content": "Typography & Alignments"
    },
    {
      "type": "inline_richtext",
      "id": "heading",
      "label": "Heading",
      "default": "Luxury Redefined"
    },
    {
      "type": "textarea",
      "id": "subheading",
      "label": "Subheading",
      "default": "Experience the premium difference in motion layouts."
    },
    {
      "type": "select",
      "id": "content_alignment",
      "label": "Content Text Alignment",
      "options": [
        { "value": "left", "label": "Left" },
        { "value": "center", "label": "Center" },
        { "value": "right", "label": "Right" }
      ],
      "default": "center"
    },
    {
      "type": "range",
      "id": "content_max_width",
      "min": 400,
      "max": 1000,
      "step": 50,
      "unit": "px",
      "label": "Content Box Max Width",
      "default": 700
    },
    {
      "type": "text",
      "id": "cta_label",
      "label": "CTA Button Label",
      "default": "Explore Now"
    },
    {
      "type": "url",
      "id": "cta_link",
      "label": "CTA Link"
    },
    {
      "type": "header",
      "content": "Colors & Spacing"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Section Background Color",
      "default": "transparent"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text Color",
      "default": "#ffffff"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Padding Top",
      "default": 0
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Padding Bottom",
      "default": 0
    }
  ],
  "presets": [
    {
      "name": "Autoplay Video Banner"
    }
  ]
}
{% endschema %}
